# Terraform state files — NEVER commit these
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform crash logs
crash.log
crash.*.log

# Terraform variable files with secrets
*.tfvars
!terraform.tfvars.example

# Terraform directories
.terraform/
.terraform.lock.hcl

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Generated import config (delete after apply)
generated.tf

# Python virtualenv
.venv/

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp